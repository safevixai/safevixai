# SafeVixAI backend environment template
# Copy these keys into .env and fill the placeholders with your real values.

ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,YOUR_FRONTEND_URL
FRONTEND_URL=http://localhost:3000
ENABLE_MCP=false
# Security
# Set this to a strong, random string (e.g., run `openssl rand -hex 32` or `python -c "import secrets; print(secrets.token_urlsafe(32))"`)
# MUST BE THE SAME IN BOTH BACKEND AND CHATBOT .ENV FILES
ADMIN_SECRET=YOUR_ADMIN_SECRET_HERE

# JWT — REQUIRED in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# If not set, an ephemeral key is generated per process (tokens won't survive restarts).
JWT_SECRET_KEY=YOUR_RANDOM_32_BYTE_OR_LONGER_JWT_SECRET
ACCESS_TOKEN_EXPIRE_HOURS=24
AUTH_OPERATOR_EMAIL=operator@safevixai.app
# Generate with: python -c "import hashlib,secrets; p='CHANGE_ME'; s=secrets.token_hex(16); i=260000; print(f'pbkdf2_sha256${i}${s}${hashlib.pbkdf2_hmac(\"sha256\", p.encode(), s.encode(), i).hex()}')"
AUTH_OPERATOR_PASSWORD_HASH=pbkdf2_sha256$260000$CHANGE_ME_SALT$CHANGE_ME_DIGEST
AUTH_OPERATOR_NAME=SafeVixAI Operator
DATABASE_URL=postgresql+asyncpg://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:6543/YOUR_DB_NAME?ssl=require
REDIS_URL=
DB_POOL_SIZE=1
DB_MAX_OVERFLOW=1
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
ROAD_PHOTO_BUCKET=road-photos
# Supabase Auth JWT verification. Use the project's JWT secret from Supabase settings.
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET
SUPABASE_JWT_AUDIENCE=authenticated

DEFAULT_RADIUS=5000
MAX_RADIUS=50000
EMERGENCY_MIN_RESULTS=3
EMERGENCY_RADIUS_STEPS=500,1000,5000,10000,25000,50000
CACHE_TTL_SECONDS=3600
GEOCODE_CACHE_TTL_SECONDS=86400
AUTHORITY_CACHE_TTL_SECONDS=3600

OVERPASS_URL=https://overpass-api.de/api/interpreter
OVERPASS_URLS=https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter,https://overpass.private.coffee/api/interpreter
NOMINATIM_URL=https://nominatim.openstreetmap.org
OPENROUTESERVICE_BASE_URL=https://api.openrouteservice.org
OPENROUTESERVICE_API_KEY=
TOMTOM_API_KEY=
HTTP_USER_AGENT="SafeVixAI/1.0 (replace-with-your-email-or-site)"
REQUEST_TIMEOUT_SECONDS=20
UPSTREAM_RETRY_ATTEMPTS=2
UPSTREAM_RETRY_BACKOFF_SECONDS=1.5
DATA_GOV_API_KEY=YOUR_DATA_GOV_API_KEY
KAGGLE_API_TOKEN=YOUR_KAGGLE_API_TOKEN

# OpenWeather
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
OPENWEATHER_UNITS=metric

CHATBOT_MODE=external_service
CHATBOT_READY=false
CHATBOT_SERVICE_URL=http://localhost:8010/api/v1
# Shared secret for internal backend↔chatbot communication.
# MUST be set to the same value in chatbot_service/.env — if unset, chatbot endpoints have no auth.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CHATBOT_INTERNAL_API_KEY=
CHATBOT_REQUEST_TIMEOUT_SECONDS=20
LOCAL_UPLOAD_BASE_URL=http://localhost:8000/uploads
MAX_UPLOAD_BYTES=5242880
ALLOWED_UPLOAD_CONTENT_TYPES=image/jpeg,image/png,image/webp
OFFLINE_BUNDLE_DIR=./data/offline_bundles
PHOTON_URL=https://photon.komoot.io
ROUTE_CACHE_TTL_SECONDS=900

# ── Production Alerting (optional) ──────────────────────────────────────────
# Email alerts when external APIs, database, or unhandled errors occur.
# Uses Gmail SMTP with App Passwords (not regular password).
# Setup: https://myaccount.google.com/apppasswords → "Mail" → "Other"
ALERT_EMAIL=YOUR_GMAIL_ADDRESS
ALERT_EMAIL_PASSWORD=YOUR_GMAIL_APP_PASSWORD
ALERT_EMAIL_TO=YOUR_RECIPIENT_EMAIL

# Missing keys appended
HEALTHSITES_TOKEN=YOUR_HEALTHSITES_TOKEN
