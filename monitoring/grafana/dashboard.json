{
  "title": "SafeVixAI — Production Observability",
  "tags": ["safevixai", "production", "india"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "panels": [
    {
      "title": "SOS Dispatch Rate",
      "type": "timeseries",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "sum(rate(sos_dispatch_total[5m])) by (status, mode)",
          "legendFormat": "{{status}} ({{mode}})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "cps", "min": 0 }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 }
    },
    {
      "title": "SOS Response Latency (p50/p95/p99)",
      "type": "timeseries",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(sos_response_time_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(sos_response_time_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(sos_response_time_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 }
    },
    {
      "title": "Emergency Lookup Rate by Source",
      "type": "timeseries",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "sum(rate(emergency_lookup_total[5m])) by (source)",
          "legendFormat": "{{source}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "cps" }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 }
    },
    {
      "title": "Emergency Services Found",
      "type": "gauge",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "avg(emergency_services_found)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "green", "value": 10 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 }
    },
    {
      "title": "Chatbot Request Rate by Intent",
      "type": "timeseries",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "sum(rate(chatbot_request_total[5m])) by (intent)",
          "legendFormat": "{{intent}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "cps" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 }
    },
    {
      "title": "Chatbot Response Latency by Provider",
      "type": "timeseries",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(chatbot_response_time_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p95 — {{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 }
    },
    {
      "title": "LLM Fallback Frequency",
      "type": "timeseries",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "sum(rate(chatbot_fallback_total[5m])) by (from_provider, to_provider)",
          "legendFormat": "{{from_provider}} → {{to_provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "cps" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 }
    },
    {
      "title": "API Error Rate (4xx / 5xx)",
      "type": "timeseries",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "sum(rate(api_request_total{status_code=~\"4..\"}[5m]))",
          "legendFormat": "4xx errors"
        },
        {
          "expr": "sum(rate(api_request_total{status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx errors"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "cps" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 }
    },
    {
      "title": "API Request Rate by Endpoint (Top 10)",
      "type": "table",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "topk(10, sum(rate(api_request_total[5m])) by (method, endpoint))",
          "legendFormat": "{{method}} {{endpoint}}",
          "format": "table"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 }
    },
    {
      "title": "Safety Blocks Triggered",
      "type": "timeseries",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "sum(rate(chatbot_safety_block_total[5m])) by (reason)",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "cps" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 }
    },
    {
      "title": "Circuit Breaker Status",
      "type": "stat",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "count(circuit_breaker_state == 0) or vector(0)",
          "legendFormat": "Closed"
        },
        {
          "expr": "count(circuit_breaker_state == 1) or vector(0)",
          "legendFormat": "Open"
        },
        {
          "expr": "count(circuit_breaker_state == 2) or vector(0)",
          "legendFormat": "Half-Open"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 24 }
    },
    {
      "title": "Active Tracking Sessions",
      "type": "stat",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "tracking_sessions_active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 24 }
    },
    {
      "title": "Cache Hit Rate",
      "type": "timeseries",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "sum(rate(cache_hit_total[5m])) / (sum(rate(cache_hit_total[5m])) + sum(rate(cache_miss_total[5m]))) * 100",
          "legendFormat": "Hit rate %"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 24 }
    },
    {
      "title": "Challan Calculation Rate",
      "type": "timeseries",
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "sum(rate(challan_calculation_total[5m])) by (source)",
          "legendFormat": "{{source}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "cps" }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 24 }
    }
  ],
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" }
}
