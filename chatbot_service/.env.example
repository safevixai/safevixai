# SafeVixAI chatbot service environment template
# Copy to .env and replace placeholders with your real values.

ENVIRONMENT=development
CHATBOT_SERVICE_NAME=SafeVixAI Chatbot Service
CHATBOT_SERVICE_PORT=8010
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,YOUR_FRONTEND_URL
# Security
# Set this to a strong, random string (e.g., run `openssl rand -hex 32` or `python -c "import secrets; print(secrets.token_urlsafe(32))"`)
# MUST BE THE SAME IN BOTH BACKEND AND CHATBOT .ENV FILES
ADMIN_SECRET=YOUR_ADMIN_SECRET_HERE

# Shared secret for internal backend↔chatbot communication.
# Backend proxies user requests here using this key (X-Internal-Api-Key header).
# If unset, chat endpoints have no auth — set in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CHATBOT_INTERNAL_API_KEY=

# Main backend connection for tools
MAIN_BACKEND_BASE_URL=YOUR_BACKEND_URL
MAIN_BACKEND_TIMEOUT_SECONDS=20

# Cache and retrieval
REDIS_URL=YOUR_REDIS_URL
CHROMA_PERSIST_DIR=./data/chroma_db
RAG_DATA_DIR=./data
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_MIN_SCORE=0.28
TOP_K_RETRIEVAL=5

# Primary / fallback providers
DEFAULT_LLM_PROVIDER=groq
DEFAULT_LLM_MODEL=llama3-70b-8192
GROQ_API_KEY=YOUR_GROQ_API_KEY
GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GITHUB_TOKEN=YOUR_GITHUB_MODELS_TOKEN
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY
TOGETHER_API_KEY=YOUR_TOGETHER_API_KEY
NVIDIA_NIM_API_KEY=YOUR_NVIDIA_NIM_API_KEY
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
HF_TOKEN=YOUR_HUGGING_FACE_TOKEN
CEREBRAS_API_KEY=YOUR_CEREBRAS_API_KEY
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
KAGGLE_API_TOKEN=YOUR_KAGGLE_API_TOKEN

# Local speech translation
SPEECH_MODEL_ID=ai4bharat/indic-seamless
SPEECH_MODEL_DIR=./data/speech_finetuning/indic-seamless
SPEECH_DEVICE=auto
SPEECH_DEFAULT_TARGET_LANG=eng

# Weather and routing
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
OPENWEATHER_UNITS=metric
OPENROUTESERVICE_API_KEY=YOUR_OPENROUTESERVICE_API_KEY
W3W_API_KEY=YOUR_WHAT3WORDS_API_KEY
OPENCAGE_API_KEY=YOUR_OPENCAGE_API_KEY

# General HTTP behavior
HTTP_TIMEOUT_SECONDS=20
HTTP_USER_AGENT="SafeVixAI/1.0 (replace-with-your-email-or-site)"

# ── Production Alerting (optional) ──────────────────────────────────────────
# Email alerts when LLM providers, external APIs, or Supabase fail.
# Uses Gmail SMTP with App Passwords (not regular password).
# Setup: https://myaccount.google.com/apppasswords → "Mail" → "Other"
ALERT_EMAIL=YOUR_GMAIL_ADDRESS
ALERT_EMAIL_PASSWORD=YOUR_GMAIL_APP_PASSWORD
ALERT_EMAIL_TO=YOUR_RECIPIENT_EMAIL

# Missing keys appended
BHARATGEN_PARAM2_MODEL=bharatgenai/param2-17b
BHARATGEN_SOOKTAM_MODEL=bharatgenai/sooktam-2
GROQ_MODEL=llama-3.3-70b-versatile
MISTRAL_MODEL=mistral-large-latest
OPENROUTER_MODEL=auto
SARVAM_105B_MODEL=sarvamai/sarvam-105b
SARVAM_30B_MODEL=sarvamai/sarvam-2b
SARVAM_API_KEY=YOUR_SARVAM_API_KEY
SARVAM_M_MODEL=sarvamai/sarvam-m
SARVAM_TRANSLATE_MODEL=sarvamai/translate-indic
SESSION_TTL_SECONDS=86400
SHUKA_MODEL=sarvamai/shuka-v1
TOGETHER_MODEL=meta-llama/Llama-3.1-70B-Instruct-Turbo
WHISPER_MODEL=openai/whisper-large-v3
