# ── SafeVixAI Frontend ENV Template ──
# 1. Copy this file to .env.local (gitignored)
# 2. Fill in real values from Vercel/Render dashboard
# 3. NEVER commit .env or .env.local

# API URLs (required)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CHATBOT_URL=http://localhost:8010

# Supabase (required — get from https://supabase.com/dashboard/project/nvwvhftzzajraeiifdks/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Map defaults (optional, sane defaults below)
NEXT_PUBLIC_MAP_DEFAULT_ZOOM=13
NEXT_PUBLIC_MAP_FALLBACK_LAT=20.5937
NEXT_PUBLIC_MAP_FALLBACK_LON=78.9629
NEXT_PUBLIC_MAP_FALLBACK_ZOOM=5
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
NEXT_PUBLIC_MAPTILER_STYLE_LIGHT=streets-v2
NEXT_PUBLIC_MAPTILER_STYLE_DARK=dataviz-dark

# Server-side API keys (used by Next.js Route Handlers — NOT exposed to client)
# MapTiler: https://cloud.maptiler.com/account/keys/
MAPTILER_API_KEY=your_maptiler_api_key
# TomTom: https://developer.tomtom.com/user/me/apps
TOMTOM_API_KEY=your_tomtom_api_key
# What3Words: https://accounts.what3words.com/billing-and-plan
W3W_API_KEY=your_w3w_api_key
