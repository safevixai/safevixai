# SafeVixAI frontend environment template
# Copy to .env and fill in real public values if needed.

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CHATBOT_URL=http://localhost:8010
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_TOMTOM_KEY=

# Server-side only. Do not prefix with NEXT_PUBLIC.
W3W_API_KEY=YOUR_WHAT3WORDS_API_KEY

# Map configuration
NEXT_PUBLIC_MAP_DEFAULT_ZOOM=13
NEXT_PUBLIC_MAP_FALLBACK_LAT=20.5937
NEXT_PUBLIC_MAP_FALLBACK_LON=78.9629
NEXT_PUBLIC_MAP_FALLBACK_ZOOM=5

# OpenFreeMap is the recommended zero-cost default.
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

# Optional: only fill these if you want MapTiler as a visual enhancement.
NEXT_PUBLIC_MAPTILER_KEY=
NEXT_PUBLIC_MAPTILER_STYLE_ID=streets-v2

# Required for Google Maps Gemini Grounding Fallback only
NEXT_PUBLIC_GMAPS_DEMO_KEY=your_demo_key_here
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Feature flags
NEXT_PUBLIC_ENABLE_CRASH_DETECTION=true
NEXT_PUBLIC_ENABLE_FAMILY_TRACKING=true
NEXT_PUBLIC_ENABLE_WEBLLM_OFFLINE=false


# Missing keys appended
NEXT_PUBLIC_APP_URL=http://localhost
NEXT_PUBLIC_MAPTILER_STYLE_DARK=dataviz-dark
NEXT_PUBLIC_MAPTILER_STYLE_LIGHT=streets-v2
NEXT_PUBLIC_MAX_UPLOAD_BYTES=5242880
