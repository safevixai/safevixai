All environment variables for frontend development.

# ── Required: Backend & Chatbot URLs ──
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_CHATBOT_URL=http://localhost:8010

# ── Optional: Analytics ──
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Optional: Sentry Error Tracking ──
# NEXT_PUBLIC_SENTRY_DSN=

# ── Optional: Feature Flags ──
# NEXT_PUBLIC_DEMO_MODE=false
# NEXT_PUBLIC_ENABLE_CRASH_DETECTION=true
# NEXT_PUBLIC_ENABLE_FAMILY_TRACKING=true
# NEXT_PUBLIC_ENABLE_WEBLLM=true

# ── Map Configuration (defaults provided) ──
# NEXT_PUBLIC_MAP_STYLE=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json
# NEXT_PUBLIC_MAP_CENTER=13.0827,80.2707
# NEXT_PUBLIC_MAP_ZOOM=12
