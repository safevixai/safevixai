# SafeVisionAI - Project-wide .gitignore

# ============================================================
# ENVIRONMENT & SECRETS - never commit these
# ============================================================
.env
.env.local
.env.production
.env.*.local
backend/.env
frontend/.env
frontend/.env.local
chatbot_service/.env

# ============================================================
# PYTHON / BACKEND
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/
.eggs/

# Machine-specific road manifest
backend/scripts/road_sources.json

# ChromaDB — local vector store (never commit, ~100MB+ binary)
backend/chroma_db/
backend/data/chroma_db/
# ChromaDB index binary artefacts
*.pickle
backend/chroma_db/**/*.bin
backend/chroma_db/**/*.pickle
backend/chroma_db/chroma.sqlite3

# Downloaded PDF source documents (regenerated by ingest script)
backend/chatbot_service/data/legal/*.pdf
backend/chatbot_service/data/medical/*.pdf
chatbot_service/data/legal/indian_kanoon/
chatbot_service/data/legal/state_amendments/

# Raw data CSVs — seeded to Supabase, not needed on Render
chatbot_service/data/accidents/
chatbot_service/data/hospitals/
chatbot_service/data/medical/
chatbot_service/data/roads/
chatbot_service/data/emergency/
chatbot_service/data/pothole_training/
chatbot_service/data/speech_finetuning/
chatbot_service/data/boundaries/
chatbot_service/data/qa_pairs/

# Alembic temp files
backend/migrations/versions/*.pyc

# ============================================================
# NODE / FRONTEND
# ============================================================
node_modules/
frontend/node_modules/
.node_modules/
frontend/.node_modules/
.next/
frontend/.next/
out/
frontend/out/

# Next.js build output
frontend/.next/static/
frontend/public/workbox-*.js
frontend/public/worker-*.js
frontend/public/fallback-*.js

# Playwright output
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/
frontend/playwright/.cache/

# Generated PWA cache files
frontend/public/sw.js.map

# ============================================================
# EDITORS & OS
# ============================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*.orig

# ============================================================
# MISC
# ============================================================
*.log
*.err
*.tmp
coverage/
.nyc_output/
.pytest_cache/
chatbot_service/pytest-cache-files-*/
.mypy_cache/
.ruff_cache/
htmlcov/

# Extracted temp files (used during setup)
doc_text.txt

# Local debug and CLI tool logs
frontend/lint_output.txt
frontend/ts-errors.txt
frontend/log.txt
frontend/ls_recursive.txt
frontend/eslint.json
frontend/.npm-cache/

# Generated local map artifacts
backend/chennai.json
backend/data/offline_bundles/
frontend/public/leaflet/

# Local dataset drops and generated offline bundles
backend/datasets/
frontend/public/leaflet/

# Skip large bulk offline bundles (frontend handles its own PWA bundle)
frontend/public/offline-data/city-bundles/
frontend/public/offline-data/translations/

# Pothole image training data
chatbot_service/data/pothole_training/

# Large boundary shapefiles
chatbot_service/data/boundaries/*.zip
frontend/public/offline-data/city-bundles/
frontend/public/offline-data/translations/

# TypeScript build cache
*.tsbuildinfo

# Local prototypes
ui_design/

# Frontend uses npm lockfile as source of truth
frontend/pnpm-lock.yaml

# ============================================================
# SCRATCH / TEMP SCRIPTS (root-level one-off scripts)
# ============================================================
read_sample.py
refactor_scripts.py
rename_and_clean.py
read_models_guide.py
models_guide_full.txt
models_guide_full_out.txt
models_guide_part2.txt
tree_output.txt
doc_text.txt
scratch_*.py
patch.py

# ============================================================
# LARGE GENERATED / DOWNLOADED DATA (regenerated by bootstrap)
# ============================================================
# PMGSY roads GeoJSON (648MB) — generated from source shapefiles
chatbot_service/data/roads/pmgsy_roads.geojson
# Emergency GeoJSON synced to frontend by bootstrap
# (included in frontend/public/offline-data — keep that copy, skip chatbot copy)
chatbot_service/data/roads/national_highways.csv

# MoRTH extracted tables (394 CSVs, large bulk) — regenerated by extract script
chatbot_service/data/morth_2022/

# MHQA QA pairs dataset (16MB, extracted from zip)
chatbot_service/data/qa_pairs/mhqa-main/

# Speech finetuning model weights (7GB Indic Seamless — download separately)
chatbot_service/data/speech_finetuning/indic-seamless/

# Render rebuilds the lightweight local-hash vectorstore from committed source docs.
# Keep large local ChromaDB binaries out of Git and Docker build context.
chatbot_service/data/chroma_db/
# ============================================================
# FRONTEND MODELS (committed individually when ready)
# ============================================================
# These are placeholder 0-byte files — will commit real ONNX when exported
# frontend/public/models/yolov8n_pothole.onnx   <- commit when exported from Colab
# frontend/public/models/maarg-risk.onnx        <- commit when trained


# Data Backup Root
/data/

# Frontend ONNX model placeholders (0-byte; commit real weights when ready)
frontend/public/models/maarg-risk.onnx
frontend/public/models/yolov8n_pothole.onnx

.vercel

# ============================================================
# AGENT / KNOWLEDGE GRAPH OUTPUTS
# ============================================================
.agents/
graphify-out/

# ============================================================
# DOCS (auto-generated audit reports, runbooks, verification)
# ============================================================
docs/audit/
docs/runbooks/
docs/test/
docs/verification_report.json

# ============================================================
# TEST OUTPUTS & CACHE
# ============================================================
tests/
frontend/tests/a11y/

# Hypothesis cache (property-based testing)
backend/.hypothesis/
